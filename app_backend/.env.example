# Metta App Backend Environment Variables Example

# Database configuration
STATS_DB_URI=postgres://username:password@host:port/database

# Server configuration
HOST=127.0.0.1
PORT=8000

# Development configuration (optional)
DEBUG_USER_EMAIL=your-email@example.com

# LLM API Keys (for training run description generation)
# At least one of these is required for LLM-powered descriptions
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Optional: Override default API URLs
# OPENAI_API_BASE=https://api.openai.com/v1/chat/completions
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1/chat/completions
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages